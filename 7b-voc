// Flatten + dedupe by English word (keep first occurrence) so quiz prompts stay unambiguous
const seen = new Set();
const ALL_WORDS = [];
Object.keys(VOCAB_RAW).forEach(unit=>{
  VOCAB_RAW[unit].forEach(([en,zh])=>{
    if(!seen.has(en)){
      seen.add(en);
      ALL_WORDS.push({en,zh,unit});
    }
  });
});

/* ================= STATE ================= */
const QUESTION_COUNT = 20;
let state = {
  student:{cls:"",seat:"",name:""},
  questions:[],
  currentIndex:0,
  records:[],      // {en, zh, attempts, gotFirstTry}
  startTime:0,
  timerHandle:null,
  currentAttempts:0,
  locked:false
};

function shuffle(arr){
  const a=[...arr];
  for(let i=a.length-1;i>0;i--){
    const j=Math.floor(Math.random()*(i+1));
    [a[i],a[j]]=[a[j],a[i]];
  }
  return a;
}

function buildQuestions(){
  const pool = shuffle(ALL_WORDS).slice(0,QUESTION_COUNT);
  return pool.map(word=>{
    const distractorsPool = ALL_WORDS.filter(w=>w.en!==word.en);
    const distractors = shuffle(distractorsPool).slice(0,3).map(w=>w.zh);
    const options = shuffle([word.zh,...distractors]);
    return {en:word.en, zh:word.zh, options};
  });
}

/* ================= SCREEN SWITCH ================= */
function showScreen(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

/* ================= START SCREEN ================= */
document.getElementById('btn-start').addEventListener('click', ()=>{
  const cls = document.getElementById('in-class').value.trim();
  const seat = document.getElementById('in-seat').value.trim();
  const name = document.getElementById('in-name').value.trim();
  const errEl = document.getElementById('start-error');
  if(!cls || !seat || !name){
    errEl.textContent = '請填寫班級、座號與姓名唷 🐾';
    return;
  }
  errEl.textContent = '';
  state.student = {cls,seat,name};
  startQuiz();
});

/* ================= QUIZ FLOW ================= */
function startQuiz(){
  state.questions = buildQuestions();
  state.currentIndex = 0;
  state.records = [];
  state.startTime = Date.now();
  showScreen('screen-quiz');
  startTimer();
  renderQuestion();
}

function startTimer(){
  clearInterval(state.timerHandle);
  updateTimerDisplay();
  state.timerHandle = setInterval(updateTimerDisplay, 500);
}
function updateTimerDisplay(){
  const secs = Math.floor((Date.now()-state.startTime)/1000);
  document.getElementById('q-timer').textContent = '⏱ ' + formatTime(secs);
}
function formatTime(totalSecs){
  const m = Math.floor(totalSecs/60).toString().padStart(2,'0');
  const s = (totalSecs%60).toString().padStart(2,'0');
  return `${m}:${s}`;
}

function renderQuestion(){
  state.currentAttempts = 0;
  state.locked = false;
  const q = state.questions[state.currentIndex];
  document.getElementById('q-progress').textContent = `第 ${state.currentIndex+1} / ${QUESTION_COUNT} 題`;
  document.getElementById('progress-fill').style.width = `${((state.currentIndex)/QUESTION_COUNT)*100}%`;
  document.getElementById('word-en').textContent = q.en;
  document.getElementById('feedback').textContent = '';
  document.getElementById('feedback').className = 'feedback';

  const wrap = document.getElementById('options-wrap');
  wrap.innerHTML = '';
  q.options.forEach(optZh=>{
    const btn = document.createElement('button');
    btn.className = 'opt';
    btn.textContent = optZh;
    btn.addEventListener('click', ()=>handleAnswer(optZh, btn));
    wrap.appendChild(btn);
  });

  const mascot = document.getElementById('mascot-quiz');
  mascot.className = 'mascot idle';
}

function handleAnswer(selectedZh, btnEl){
  if(state.locked) return;
  const q = state.questions[state.currentIndex];
  const isCorrect = selectedZh === q.zh;
  state.currentAttempts++;

  const feedback = document.getElementById('feedback');
  const mascot = document.getElementById('mascot-quiz');
  const allOpts = document.querySelectorAll('#options-wrap .opt');

  if(isCorrect){
    state.locked = true;
    allOpts.forEach(o=>o.disabled = true);
    btnEl.classList.add('correct');
    feedback.textContent = 'Good job! 🎉';
    feedback.className = 'feedback good';
    mascot.className = 'mascot happy';

    state.records.push({
      en: q.en,
      zh: q.zh,
      attempts: state.currentAttempts,
      gotFirstTry: state.currentAttempts === 1
    });

    setTimeout(()=>{
      state.currentIndex++;
      if(state.currentIndex >= QUESTION_COUNT){
        finishQuiz();
      } else {
        renderQuestion();
      }
    }, 700);
  } else {
    btnEl.classList.add('wrong');
    btnEl.disabled = true;
    feedback.textContent = 'Try again! 💪';
    feedback.className = 'feedback bad';
    mascot.className = 'mascot sad';
    setTimeout(()=>{ mascot.className = 'mascot idle'; }, 500);
  }
}

/* ================= RESULT SCREEN ================= */
function finishQuiz(){
  clearInterval(state.timerHandle);
  const totalSecs = Math.floor((Date.now()-state.startTime)/1000);
  const firstTryCount = state.records.filter(r=>r.gotFirstTry).length;
  const accuracy = Math.round((firstTryCount/QUESTION_COUNT)*100);

  document.getElementById('result-name').textContent =
    `${state.student.cls} 班 ${state.student.seat} 號 ${state.student.name}`;
  document.getElementById('result-title').textContent =
    accuracy >= 80 ? '太棒了！你是單字小達人！' :
    accuracy >= 50 ? '做得不錯，繼續加油！' : '再接再厲，你可以更棒！';

  document.getElementById('stat-accuracy').textContent = accuracy + '%';
  document.getElementById('stat-time').textContent = formatTime(totalSecs);
  document.getElementById('stat-correct').textContent = `${firstTryCount}/${QUESTION_COUNT}`;

  const tbl = document.getElementById('review-body');
  let rows = `<tr><th>#</th><th>英文單字</th><th>正確意思</th><th>結果</th><th>嘗試次數</th></tr>`;
  state.records.forEach((r,i)=>{
    rows += `<tr class="${r.gotFirstTry?'':'miss'}">
      <td>${i+1}</td>
      <td>${escapeHtml(r.en)}</td>
      <td>${escapeHtml(r.zh)}</td>
      <td class="${r.gotFirstTry?'badge-ok':'badge-miss'}">${r.gotFirstTry?'✅ 首答對':'🔁 重試後對'}</td>
      <td>${r.attempts}</td>
    </tr>`;
  });
  tbl.innerHTML = rows;

  showScreen('screen-result');
}

function escapeHtml(str){
  const d = document.createElement('div');
  d.textContent = str;
  return d.innerHTML;
}

/* ================= REPLAY ================= */
document.getElementById('btn-replay').addEventListener('click', ()=>{
  startQuiz();
});
